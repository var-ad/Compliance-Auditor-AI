GROQ_API_KEY=
GITHUB_TOKEN=
SUPABASE_URL=
SUPABASE_KEY=
# Required in production. Users enter this in the frontend access screen.
AUDIT_API_KEY=
LLM_MODEL=llama-3.1-8b-instant

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=https://complianceauditor.varad.fyi,http://localhost:5173

# Optional regex for Vercel preview deployments.
# CORS_ORIGIN_REGEX=https://compliance-frontend-[a-z0-9-]+\.vercel\.app
CORS_ORIGIN_REGEX=

# Host headers accepted by FastAPI/Starlette.
ALLOWED_HOSTS=auditor.varad.fyi,localhost,127.0.0.1
